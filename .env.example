# ─────────────────────────────────────────────────────────────────────────────
# Swasthya Sathi — Environment Configuration
# Copy this file to .env and fill in values as needed.
# All values shown are the defaults used when not set.
# ─────────────────────────────────────────────────────────────────────────────

# App identity
APP_NAME=Swasthya Sathi

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit server
STREAMLIT_PORT=8501

# URL the Streamlit frontend uses to reach the FastAPI backend
# When running in Docker (single container), localhost works fine.
# For separate containers, use the service name: http://api:8000
BACKEND_URL=http://localhost:8000

# Default language for responses (en=English, hi=Hindi)
DEFAULT_LANGUAGE=en

# HuggingFace Whisper model for speech-to-text
# Options: openai/whisper-tiny (fastest), openai/whisper-base, openai/whisper-small
WHISPER_MODEL=openai/whisper-tiny

# Sentence-Transformers embedding model for RAG
# all-MiniLM-L6-v2 is fast and small; good for CPU
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# OpenFDA API base URL (free, no key required)
OPENFDA_BASE_URL=https://api.fda.gov/drug/label.json

# Optional: HuggingFace Hub token (only needed for gated/private models)
# HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxx
